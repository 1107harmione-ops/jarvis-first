# Jarvis Voice Productivity Assistant — Environment Configuration
# Copy to .env and customize:
#   cp .env.example .env

# ── App ────────────────────────────────────────────────────────
APP_NAME=Jarvis
APP_VERSION=0.1.0
DEBUG=true

# ── Server ─────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database ───────────────────────────────────────────────────
# SQLite (default, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./jarvis.db

# MongoDB (optional — uncomment to use instead of SQLite):
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB_NAME=jarvis

# ── Groq API (optional — LLM inference for AI features) ────────
# Get a free API key at https://console.groq.com
# GROQ_API_KEY=gsk_your_api_key_here
# GROQ_MODEL=mixtral-8x7b-32768
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_MAX_TOKENS=4096
# GROQ_TEMPERATURE=0.7

# ── OpenCode Zen API (optional — AI code assistance) ──────────
# OPENCODE_ZEN_API_KEY=your_api_key_here
# OPENCODE_ZEN_MODEL=gpt-4o-mini
# OPENCODE_ZEN_BASE_URL=
# OPENCODE_ZEN_MAX_TOKENS=2048

# ── Redis (optional — for RQ reminder scheduler) ───────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# Full URL override (takes precedence over host/port/db above):
# REDIS_URL=redis://:password@localhost:6379/0

# ── RQ (Redis Queue) ──────────────────────────────────────────
RQ_QUEUE_NAME=jarvis
RQ_DEFAULT_TIMEOUT=300

# ── Reminder Checker (async fallback, runs without Redis) ─────
REMINDER_CHECK_INTERVAL=60

# ── Vosk STT (Speech-to-Text) ─────────────────────────────────
VOSK_MODEL_PATH=./models/vosk-model-small-en-us-0.15
VOSK_SAMPLE_RATE=16000

# ── Edge TTS (Text-to-Speech) ─────────────────────────────────
TTS_VOICE=en-US-AriaNeural

# ── Voice Activity Detection ───────────────────────────────────
VAD_MODE=1
VAD_FRAME_MS=30
VAD_ENERGY_THRESHOLD=300.0

# ── Wake Word ──────────────────────────────────────────────────
WAKE_WORD_ENABLED=false
WAKE_WORD_SENSITIVITY=0.5
WAKE_WORD_KEYWORDS=jarvis,hey jarvis
WAKE_WORD_ENERGY_THRESHOLD=500.0

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Paths ──────────────────────────────────────────────────────
DATA_DIR=./data
