# Jarvis Voice Assistant — Environment Configuration
APP_NAME=Jarvis
APP_VERSION=0.1.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./jarvis.db

# Vosk STT
VOSK_MODEL_PATH=./models/vosk-model-small-en-us-0.15
VOSK_SAMPLE_RATE=16000

# TTS
TTS_VOICE=en-US-AriaNeural

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
