# JARVIS Backend Environment Configuration
# Copy this file to .env and fill in your values

# ── App Core ──────────────────────────────────────────────────
APP_NAME=JARVIS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
CORS_ORIGINS=*
RATE_LIMIT_PER_MINUTE=60

# ── MongoDB ───────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/jarvis
MONGODB_DATABASE=jarvis

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── DeepSeek (Router + Assistant) ─────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Codex / OpenAI (Coding Agent) ─────────────────────────────
CODEX_API_KEY=
CODEX_BASE_URL=https://api.openai.com/v1
CODEX_MODEL=gpt-4o

# ── Minimax (Research Agent) ──────────────────────────────────
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=minimax-m2.1

# ── Mimo (Vision Agent) ───────────────────────────────────────
MIMO_API_KEY=
MIMO_BASE_URL=https://api.mimo.com/v1
MIMO_MODEL=mimo-v2-omni

# ── Memory Settings ───────────────────────────────────────────
MEMORY_STM_TTL_HOURS=24
MEMORY_LTM_IMPORTANCE_THRESHOLD=0.6
MEMORY_VECTOR_DIMENSION=384
MEMORY_MAX_CONTEXT_TOKENS=4096

# ── Voice Settings ────────────────────────────────────────────
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=alloy
VOICE_SESSION_TIMEOUT_SECONDS=300

# ── Tasks ─────────────────────────────────────────────────────
TASK_MAX_RETRIES=3
TASK_BACKGROUND_POLL_SECONDS=30

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s | %(levelname)-8s | %(name)s:%(funcName)s:%(lineno)d | %(message)s"

# ── Redis (Optional) ─────────────────────────────────────────
REDIS_URL=
