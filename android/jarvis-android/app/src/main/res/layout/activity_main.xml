<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="16dp">

    <!-- Connection Status -->
    <TextView
        android:id="@+id/connectionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Disconnected"
        android:textColor="#FF5252"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Battery Status -->
    <TextView
        android:id="@+id/batteryStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FF9800"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/connectionStatus"
        app:layout_constraintEnd_toStartOf="@id/offlineIndicator"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="12dp" />

    <!-- Offline Indicator -->
    <TextView
        android:id="@+id/offlineIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OFFLINE"
        android:textColor="#FF9800"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- State Text -->
    <TextView
        android:id="@+id/stateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/idle_text"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/connectionStatus" />

    <!-- Audio Level Visualization -->
    <com.jarvis.voice.ui.AudioLevelView
        android:id="@+id/audioLevelView"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/stateText" />

    <!-- Transcript Text -->
    <TextView
        android:id="@+id/transcriptText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:minHeight="48dp"
        android:text=""
        android:textColor="#B0B0B0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/audioLevelView" />

    <!-- Response Text -->
    <TextView
        android:id="@+id/responseText"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/statusLayout"
        app:layout_constraintTop_toBottomOf="@id/transcriptText" />

    <!-- Status Indicators (between response and controls) -->
    <LinearLayout
        android:id="@+id/statusLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout">

        <!-- Queued Command Count -->
        <TextView
            android:id="@+id/queuedCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FF9800"
            android:textSize="12sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Controls Layout - Row 1 -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout2">

        <!-- Interrupt Button -->
        <ImageButton
            android:id="@+id/interruptButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/circular_button_background"
            android:contentDescription="Interrupt"
            android:enabled="false"
            android:src="@android:drawable/ic_media_pause"
            android:tint="#FFFFFF" />

        <!-- Server Language Toggle (STT/TTS) -->
        <ToggleButton
            android:id="@+id/languageToggle"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:checked="false"
            android:textOff="EN"
            android:textOn="HI"
            android:textSize="13sp" />

        <!-- UI Language Toggle -->
        <ToggleButton
            android:id="@+id/uiLanguageToggle"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:checked="false"
            android:textOff="UI EN"
            android:textOn="UI HI"
            android:textSize="11sp" />

        <!-- Wake Word Toggle -->
        <ToggleButton
            android:id="@+id/wakeWordToggle"
            android:layout_width="72dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:checked="true"
            android:textOff="Wake Off"
            android:textOn="Wake On"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- Controls Layout - Row 2 (offline mode) -->
    <LinearLayout
        android:id="@+id/controlsLayout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Offline Mode Toggle -->
        <ToggleButton
            android:id="@+id/offlineModeToggle"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:checked="false"
            android:textOff="Online"
            android:textOn="Offline"
            android:textSize="12sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
